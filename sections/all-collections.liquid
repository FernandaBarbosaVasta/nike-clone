{% assign my_collections = 'air-force,best-sellers,only-at-nike' | split: ',' %}

<section class="all-collections">
  <h1>Featured Collections</h1>
  <div class="collection-container">
    <div class="all-collections-wrapper">
      {% for handle in my_collections %}
        {% assign col = collections[handle] %}
        <div class="collection-card">
          <a href="{{ col.url }}">
            <img
              width="300"
              height="300"
              loading="lazy"
              src="{{ col.featured_image | image_url }}"
              alt="{{ col.title | escape }}"
            >
          </a>
          <h3>{{ col.title | link_to: col.url }}</h3>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
    .all-collections {
      background: {{ section.settings.background }}
      ;
      ;
      padding: 10px;
    }

    .all-collections h1 {
      text-align: center;
    }
  
    .collection-container {
      position: relative;
      overflow-x: hidden;
    }
  
    .all-collections-wrapper {
      display: flex;
      justify-content: center;
      transition: transform 0.3s ease; /* Add smooth transition effect */
    }
  
    .collection-card {
      padding: 5px;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .collection-card img {
      display: block;
      max-width: 100%;
      height: auto;
      border-radius: 10px;
      box-shadow: 0 0 10px 0 rgba(0, 0, 0, 0.1);
      transition: transform 0.3s ease;
      &:hover {
        transform: scale(1.02);
      }
    }

    .collection-card h3 a {
      color: inherit;
      text-decoration: none
    }
  
    .collection-card a:hover {
      text-decoration: underline;
      color:rgb(170, 167, 167);
    }
  </style>

{% schema %}
{
  "name": "all-collections",
  "settings": [
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "all-collections"
    }
  ]
}
{% endschema %}
