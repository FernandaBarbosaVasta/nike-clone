<section class="banner" id="banner-{{ section.id }}">
    <div class="banner-wrapper">
        <div class="slide-text" data-slide-text><p>Members: Free Shipping!</p></div>
        <div class="slide-text" data-slide-text>Save Up to 40%</div>
        <div class="slide-text" data-slide-text>Get Your Gear Faster</div>
    </div>
</section>

<style>
    #banner-{{ section.id }} .banner-wrapper {
      position: relative;
      overflow: hidden;
      min-height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: {{ section.settings.background }};
      color: {{ section.settings.text_color }};
    }

    #banner-{{ section.id }} .slide-text {
        position: absolute;
        top: 50%;
        left: -100%;
        width: 100%;
        margin: 0;
        padding: 12px 20px;
        font-size: 20px;
        text-align: center;
        white-space: nowrap;
        transform: translateY(-50%);
        transition: left 0.5s ease-in-out, transform 0.5s ease-in-out;
      }

    #banner-{{ section.id }} .slide-text.is-active {
        left: 50%;
        transform: translate(-50%, -50%);
      }
  </style>

  <script>
    (function () {
      var sectionId = '{{ section.id }}';
      var intervalId = null;

      function initBannerSlider() {
        var section = document.getElementById('banner-' + sectionId);
        if (!section) return;

        var texts = section.querySelectorAll('[data-slide-text]');
        if (!texts.length) return;

        if (intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }

        var currentIndex = 0;

        function setActive(index) {
          for (var i = 0; i < texts.length; i++) {
            texts[i].classList.toggle('is-active', i === index);
          }
        }

        function slideText() {
          currentIndex = (currentIndex + 1) % texts.length;
          setActive(currentIndex);
        }

        setActive(currentIndex);
        intervalId = setInterval(slideText, 3000);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initBannerSlider);
      } else {
        initBannerSlider();
      }

      document.addEventListener('shopify:section:load', function (event) {
        if (event.target && event.target.id === 'shopify-section-' + sectionId) {
          initBannerSlider();
        }
      });

      document.addEventListener('shopify:section:unload', function (event) {
        if (event.target && event.target.id === 'shopify-section-' + sectionId && intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }
      });
    })();
  </script>

{% schema %}
{
    "name": "Banner",
    "settings": [
        {
            "type": "color",
            "id": "background",
            "label": "Background",
            "default": "#F4F4F4"
          },
          {
            "type": "color",
            "id": "text_color",
            "label": "Text",
            "default": "#000000"
          }
    ],
    "presets": [
        {
            "name": "Banner"
        }
    ]
}
{% endschema %}